<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<ExtensionManifest
  Version="7.0"
  ExtensionBundleId="com.amverge.ae.panel"
  ExtensionBundleVersion="0.2.0"
  ExtensionBundleName="AMVerge"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
>
  <ExtensionList>
    <Extension Id="com.amverge.ae.panel.main" Version="0.2.0" />
  </ExtensionList>

  <ExecutionEnvironment>
    <HostList>
      <Host Name="AEFT" Version="[16.0,99.9]" />
    </HostList>

    <LocaleList>
      <Locale Code="All" />
    </LocaleList>

    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="9.0" />
    </RequiredRuntimeList>
  </ExecutionEnvironment>

  <DispatchInfoList>
    <Extension Id="com.amverge.ae.panel.main">
      <DispatchInfo>
        <Resources>
          <MainPath>./client/app/index.html</MainPath>
          <ScriptPath>./host/index.jsx</ScriptPath>
          <CEFCommandLine>
            <Parameter>--enable-nodejs</Parameter>
            <Parameter>--mixed-context</Parameter>
          </CEFCommandLine>
        </Resources>

        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>

        <UI>
          <Type>Panel</Type>
          <Menu>AMVerge</Menu>
          <Geometry>
            <Size>
              <Height>680</Height>
              <Width>420</Width>
            </Size>
            <MinSize>
              <Height>560</Height>
              <Width>360</Width>
            </MinSize>
            <MaxSize>
              <Height>1080</Height>
              <Width>1200</Width>
            </MaxSize>
          </Geometry>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>
